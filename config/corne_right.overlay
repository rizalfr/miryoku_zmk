/*
 * Use Corne's 5-column physical layout for Miryoku on 3x6 Corne PCBs.
 *
 * The physical PCB still has 6 columns per half, but Miryoku uses the inner
 * 5 columns plus 3 thumbs. Selecting the 5col layout drops the outside columns
 * in the scan-to-keymap position map so the second physical column starts at Q.
 */

/ {
    chosen {
        zmk,physical-layout = &foostan_corne_5col_layout;
    };
};

/*
 * The stock five_column_transform uses columns = 10 with col-offset = 6 for
 * this half. The dropped outer column (raw col 5) then lands at logical
 * column 11, but row * 10 + 11 overflows into the next row's index range
 * (row1's RC(1,1) and row2's RC(2,1)), so that switch ghost-presses "a"/"z"
 * instead of doing nothing. Widening columns to 12 gives the dropped column
 * room to land outside any row's valid range.
 */
&five_column_transform {
    columns = <12>;
};
